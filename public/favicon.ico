<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="none">
  <!-- 1. Background -->
  <rect width="16" height="16" rx="3.5" fill="#0F172A" class="dark-mode-bg" />
  
  <!-- 2. "H" drawn in Emerald Green (#10B981) with a connected crossbar -->
  <path d="M4.5 5.5v5 M4.5 8h4 M8.5 5.5v5" 
        stroke="#10B981" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round" />
        
  <!-- 3. "D" drawn in Sky Blue (#38BDF8) to match the two-tone theme -->
  <path d="M11 5.5v5 M11 5.5c1.25 0 2 0.75 2 2.5c0 1.75-0.75 2.5-2 2.5" 
        stroke="#38BDF8" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round" />

  <!-- 4. Added dark mode CSS logic -->
  <style>
    @media (prefers-color-scheme: dark) {
      .dark-mode-bg { fill: #020617; }
    }
  </style>
</svg>